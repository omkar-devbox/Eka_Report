# FastAPI Settings
APP_NAME="EKA Report API"
APP_ENV="dev"
HOST="127.0.0.1"
PORT=8000

# JWT Auth Settings (generate strong secrets for production)
JWT_SECRET_KEY="your-long-random-access-token-secret-here"
JWT_REFRESH_SECRET_KEY="your-long-random-refresh-token-secret-here"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_DB_NAME="auth.db"

# Database Settings
DB_SERVER="localhost"
DB_PORT=1433
DB_DATABASE="your_db_name"
DB_USERNAME="your_username"
DB_PASSWORD="your_password"
DB_DRIVER="ODBC Driver 17 for SQL Server"
DB_TRUST_SERVER_CERTIFICATE="yes"
